# Xcode
*.xcodeproj
xcuserdata/
DerivedData/
*.xcuserstate
build/
.build-sim/

# Swift Package Manager
# Build artifacts only — source trees under Packages/ (e.g. MeisterKit) must be tracked
Packages/.build/
Packages/*/build/
.build/
.swiftpm/
Package.resolved

# macOS
.DS_Store

__pycache__/
*.pyc

# Local agent/build/cache state
# (Exception: .claude/ is tracked for committed commands/, hooks/, and status/ docs per project rules.
#  Runtime/local agent state inside .claude/ should use subpath ignores if needed in future.)
.pytest_cache/
.ruff_cache/
.mypy_cache/
*.tsbuildinfo

# Local automation locks
.auto-ship.lock

# Git worktrees
.worktrees/
